# Supabase Configuration
# Get these values from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI Provider Configuration (set in Supabase Dashboard → Edge Functions → Secrets)
# Options: "gemini" (FREE) or "openai"
# Default: gemini
AI_PROVIDER=gemini

# API Keys (DO NOT put in this file - configure in Supabase Dashboard)
# For Gemini (FREE tier with 60 requests/min):
# - Get your key at: https://makersuite.google.com/app/apikey
# - Add as secret: GEMINI_API_KEY=your-gemini-api-key
#
# For OpenAI (paid):
# - Get your key at: https://platform.openai.com/api-keys
# - Add as secret: OPENAI_API_KEY=your-openai-api-key
